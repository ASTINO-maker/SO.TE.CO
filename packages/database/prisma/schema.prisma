  @@index([projectId, isPrimary])
  @@index([quotationId, isPrimary])
  @@index([invoiceId, isPrimary])
  @@index([deliveryNoteId, isPrimary])
  @@map("document_links")
}

model Supplier {
  id             String          @id @default(cuid())
  tenantId       String
  branchId       String?
  code           String
  name           String
  taxId          String?
  email          String?
  phone          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  postalCode     String?
  status         SupplierStatus  @default(ACTIVE)
  internalNotes  String?
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  expenses       Expense[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@map("suppliers")
}

model PurchaseOrder {
  id                   String               @id @default(cuid())
  tenantId             String
  branchId             String?
  warehouseId          String?
  supplierId           String
  numberingSequenceId  String?
  createdByUserId      String?
  number               String
  status               PurchaseOrderStatus  @default(DRAFT)
  orderDate            DateTime
  expectedDate         DateTime?
  currency             String               @default("TND")
  subtotalAmount       Decimal              @default(0) @db.Decimal(14, 3)
  taxAmount            Decimal              @default(0) @db.Decimal(14, 3)
  totalAmount          Decimal              @default(0) @db.Decimal(14, 3)
  internalNotes        String?
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouse            Warehouse?           @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  supplier             Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  numberingSequence    NumberingSequence?   @relation(fields: [numberingSequenceId], references: [id], onDelete: SetNull)
  createdBy            User?                @relation("PurchaseOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items                PurchaseOrderItem[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([supplierId, orderDate])
  @@index([tenantId, deletedAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String          @id @default(cuid())
  tenantId         String
  purchaseOrderId  String
  sortOrder        Int
  productId        String?
  serviceId        String?
  unitId           String?
  inventoryItemId  String?
  description      String
  quantity         Decimal         @db.Decimal(14, 3)
  receivedQuantity Decimal         @default(0) @db.Decimal(14, 3)
  unitPrice        Decimal         @db.Decimal(14, 3)
  taxRate          Decimal         @default(0) @db.Decimal(5, 2)
  lineTotal        Decimal         @db.Decimal(14, 3)
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  service          Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  unit             Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  inventoryItem    InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([purchaseOrderId, sortOrder])
  @@map("purchase_order_items")
}

model InventoryItem {
  id               String               @id @default(cuid())
  tenantId         String
  warehouseId      String?
  productId        String?
  code             String
  name             String
  description      String?
  quantityOnHand   Decimal              @default(0) @db.Decimal(14, 3)
  reservedQuantity Decimal              @default(0) @db.Decimal(14, 3)
  reorderPoint     Decimal?             @db.Decimal(14, 3)
  status           InventoryItemStatus  @default(ACTIVE)
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse        Warehouse?           @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  product          Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements   StockMovement[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@map("inventory_items")
}

model StockMovement {
  id              String             @id @default(cuid())
  tenantId        String
  inventoryItemId String
  fromWarehouseId String?
  toWarehouseId   String?
  createdByUserId String?
  movementType    StockMovementType
  referenceType   String?
  referenceId     String?
  quantity        Decimal            @db.Decimal(14, 3)
  unitCost        Decimal?           @db.Decimal(14, 3)
  notes           String?
  occurredAt      DateTime
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  fromWarehouse   Warehouse?         @relation("StockMovementFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  toWarehouse     Warehouse?         @relation("StockMovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: SetNull)
  createdBy       User?              @relation("StockMovementCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())

  @@index([inventoryItemId, occurredAt])
  @@index([tenantId, movementType, occurredAt])
  @@map("stock_movements")
}
