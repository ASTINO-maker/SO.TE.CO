generator client {
  provider      = "prisma-client-js"
  // "windows" is required so the installer bundle works on the client machine.
  // "native" + "darwin-arm64" cover macOS dev (Intel + Apple Silicon).
  binaryTargets = ["native", "darwin-arm64", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT_SCHEDULED
  QUOTATION_IN_PROGRESS
  QUOTED
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  REFERRAL
  WEBSITE
  PHONE
  WALK_IN
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  OTHER
}

enum LeadActivityType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  SITE_VISIT
  NOTE
  STATUS_CHANGE
  QUOTATION_CREATED
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum NoteVisibility {
  INTERNAL
  CLIENT_SHARED
}

enum QuotationStatus {
  DRAFT
  SENT
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  PARTIALLY_ALLOCATED
  ALLOCATED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CARD
  OTHER
}

enum DeliveryStatus {
  DRAFT
  PREPARED
  IN_TRANSIT
  DELIVERED
  PARTIALLY_DELIVERED
  RETURNED
  CANCELLED
}

enum ProjectStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectStageStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectAssignmentRole {
  MANAGER
  ENGINEER
  FOREMAN
  FABRICATOR
  INSTALLER
  ACCOUNTANT
  OBSERVER
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum CategoryKind {
  PRODUCT
  SERVICE
  BOTH
}

enum UnitType {
  QUANTITY
  LENGTH
  AREA
  VOLUME
  WEIGHT
  TIME
}

enum FileKind {
  IMAGE
  PDF
  CONTRACT
  DRAWING
  INVOICE_ATTACHMENT
  DELIVERY_ATTACHMENT
  OTHER
}

enum FileVisibility {
  INTERNAL
  CLIENT_SHARED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  STATUS_CHANGE
  LOGIN
  LOGOUT
}

enum ActivityLogType {
  CRM
  COMMERCIAL
  BILLING
  LOGISTICS
  PROJECT
  DOCUMENT
  AUTH
  SYSTEM
}

enum NumberingDocumentType {
  QUOTATION
  INVOICE
  DELIVERY_NOTE
  PROJECT
  PURCHASE_ORDER
  PAYMENT
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum InventoryItemStatus {
  ACTIVE
  INACTIVE
  OBSOLETE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  RESERVED
  RELEASE
}

model Tenant {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  currency               String                  @default("TND")
  timezone               String                  @default("Africa/Tunis")
  branches               Branch[]
  warehouses             Warehouse[]
  users                  User[]
  roles                  Role[]
  permissions            Permission[]
  refreshTokens          RefreshToken[]
  auditLogs              AuditLog[]
  activityLogs           ActivityLog[]
  settings               Setting[]
  numberingSequences     NumberingSequence[]
  clients                Client[]
  clientContacts         ClientContact[]
  leads                  Lead[]
  leadActivities         LeadActivity[]
  notes                  Note[]
  quotations             Quotation[]
  quotationItems         QuotationItem[]
  quotationStatusHistory QuotationStatusHistory[]
  invoices               Invoice[]
  invoiceItems           InvoiceItem[]
  payments               Payment[]
  paymentAllocations     PaymentAllocation[]
  expenseCategories      ExpenseCategory[]
  expenses               Expense[]
  deliveryNotes          DeliveryNote[]
  deliveryNoteItems      DeliveryNoteItem[]
  vehicles               Vehicle[]
  deliveryStatusHistory  DeliveryStatusHistory[]
  projects               Project[]
  projectStages          ProjectStage[]
  projectStatusHistory   ProjectStatusHistory[]
  projectTasks           ProjectTask[]
  projectAssignments     ProjectAssignment[]
  projectFiles           ProjectFile[]
  projectMeasurements    ProjectMeasurement[]
  categories             Category[]
  units                  Unit[]
  products               Product[]
  services               Service[]
  files                  File[]
  documentLinks          DocumentLink[]
  suppliers              Supplier[]
  purchaseOrders         PurchaseOrder[]
  purchaseOrderItems     PurchaseOrderItem[]
  inventoryItems         InventoryItem[]
  stockMovements         StockMovement[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@map("tenants")
}

model Branch {
  id                 String              @id @default(cuid())
  tenantId           String
  name               String
  code               String
  city               String?
  addressLine1       String?
  addressLine2       String?
  postalCode         String?
  phone              String?
  email              String?
  isActive           Boolean             @default(true)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users              User[]
  clients            Client[]
  leads              Lead[]
  quotations         Quotation[]
  invoices           Invoice[]
  payments           Payment[]
  expenses           Expense[]
  deliveryNotes      DeliveryNote[]
  vehicles           Vehicle[]
  projects           Project[]
  warehouses         Warehouse[]
  purchaseOrders     PurchaseOrder[]
  settings           Setting[]
  numberingSequences NumberingSequence[]
  suppliers          Supplier[]
  auditLogs          AuditLog[]
  activityLogs       ActivityLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@map("branches")
}

model Warehouse {
  id                 String          @id @default(cuid())
  tenantId           String
  branchId           String?
  code               String
  name               String
  location           String?
  notes              String?
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  inventoryItems     InventoryItem[]
  purchaseOrders     PurchaseOrder[]
  fromStockMovements StockMovement[] @relation("StockMovementFromWarehouse")
  toStockMovements   StockMovement[] @relation("StockMovementToWarehouse")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@map("warehouses")
}

model User {
  id                          String                @id @default(cuid())
  tenantId                    String
  branchId                    String?
  firstName                   String
  lastName                    String
  email                       String
  phone                       String?
  passwordHash                String?
  status                      UserStatus            @default(INVITED)
  lastLoginAt                 DateTime?
  tenant                      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                      Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userRoles                   UserRole[]
  refreshTokens               RefreshToken[]
  assignedLeads               Lead[]                @relation("LeadAssignedUser")
  leadActivities              LeadActivity[]
  notes                       Note[]
  createdQuotations           Quotation[]           @relation("QuotationCreatedBy")
  quotationStatusHistory      QuotationStatusHistory[] @relation("QuotationStatusChangedBy")
  createdInvoices             Invoice[]             @relation("InvoiceCreatedBy")
  receivedPayments            Payment[]             @relation("PaymentReceivedBy")
  paymentAllocations          PaymentAllocation[]   @relation("PaymentAllocationByUser")
  createdDeliveryNotes        DeliveryNote[]        @relation("DeliveryNoteCreatedBy")
  deliveryStatusHistory       DeliveryStatusHistory[] @relation("DeliveryStatusChangedBy")
  managedProjects             Project[]             @relation("ProjectManager")
  createdProjects             Project[]             @relation("ProjectCreatedBy")
  projectStatusHistory        ProjectStatusHistory[] @relation("ProjectStatusChangedBy")
  assignedProjectTasks        ProjectTask[]         @relation("ProjectTaskAssignedTo")
  createdProjectTasks         ProjectTask[]         @relation("ProjectTaskCreatedBy")
  projectAssignments          ProjectAssignment[]
  uploadedProjectFiles        ProjectFile[]         @relation("ProjectFileUploadedBy")
  capturedProjectMeasurements ProjectMeasurement[]  @relation("ProjectMeasurementCapturedBy")
  createdExpenses             Expense[]             @relation("ExpenseCreatedBy")
  approvedExpenses            Expense[]             @relation("ExpenseApprovedBy")
  uploadedFiles               File[]                @relation("FileUploadedBy")
  createdDocumentLinks        DocumentLink[]        @relation("DocumentLinkCreatedBy")
  createdPurchaseOrders       PurchaseOrder[]       @relation("PurchaseOrderCreatedBy")
  createdStockMovements       StockMovement[]       @relation("StockMovementCreatedBy")
  auditLogs                   AuditLog[]
  activityLogs                ActivityLog[]
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  deletedAt                   DateTime?

  @@unique([tenantId, email])
  @@index([tenantId, deletedAt])
  @@map("users")
}

model Role {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  code            String
  description     String?
  isSystemRole    Boolean          @default(false)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  tenantId        String
  code            String
  label           String
  description     String?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())

  @@unique([tenantId, code])
  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  tokenHash  String   @unique
  issuedAt   DateTime @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, revokedAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String
  branchId   String?
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, action, createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id         String          @id @default(cuid())
  tenantId   String
  branchId   String?
  userId     String?
  type       ActivityLogType
  message    String
  entityType String?
  entityId   String?
  metadata   Json?
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now())

  @@index([tenantId, type, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("activity_logs")
}

model Setting {
  id          String    @id @default(cuid())
  tenantId    String
  branchId    String?
  scopeKey    String    @default("global")
  key         String
  value       Json
  isSecret    Boolean   @default(false)
  description String?
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([tenantId, scopeKey, key])
  @@index([tenantId, deletedAt])
  @@map("settings")
}

model NumberingSequence {
  id            String                @id @default(cuid())
  tenantId      String
  branchId      String?
  scopeKey      String                @default("global")
  documentType  NumberingDocumentType
  prefix        String
  suffix        String?
  separator     String                @default("-")
  currentValue  Int                   @default(0)
  padding       Int                   @default(5)
  fiscalYear    Int?
  resetYearly   Boolean               @default(true)
  isActive      Boolean               @default(true)
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  quotations    Quotation[]
  invoices      Invoice[]
  deliveryNotes DeliveryNote[]
  projects      Project[]
  purchaseOrders PurchaseOrder[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deletedAt     DateTime?

  @@unique([tenantId, scopeKey, documentType, fiscalYear])
  @@index([tenantId, deletedAt])
  @@map("numbering_sequences")
}

model Client {
  id                   String          @id @default(cuid())
  tenantId             String
  branchId             String?
  convertedFromLeadId  String?         @unique
  code                 String
  type                 ClientType      @default(INDIVIDUAL)
  displayName          String
  legalName            String?
  taxId                String?
  registrationNo       String?
  email                String?
  phone                String?
  mobile               String?
  city                 String?
  addressLine1         String?
  addressLine2         String?
  postalCode           String?
  creditLimit          Decimal?        @db.Decimal(14, 3)
  isActive             Boolean         @default(true)
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  convertedFromLead    Lead?           @relation("LeadConvertedClient", fields: [convertedFromLeadId], references: [id], onDelete: SetNull)
  contacts             ClientContact[]
  quotations           Quotation[]
  invoices             Invoice[]
  payments             Payment[]
  deliveryNotes        DeliveryNote[]
  projects             Project[]
  notes                Note[]
  documentLinks        DocumentLink[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, displayName])
  @@index([tenantId, deletedAt])
  @@map("clients")
}

model ClientContact {
  id         String   @id @default(cuid())
  tenantId   String
  clientId   String
  firstName  String
  lastName   String
  jobTitle   String?
  email      String?
  phone      String?
  mobile     String?
  isPrimary  Boolean  @default(false)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([tenantId, deletedAt])
  @@index([clientId, isPrimary])
  @@map("client_contacts")
}

model Lead {
  id              String          @id @default(cuid())
  tenantId        String
  branchId        String?
  assignedUserId  String?
  fullName        String
  companyName     String?
  email           String?
  phone           String?
  source          LeadSource      @default(OTHER)
  status          LeadStatus      @default(NEW)
  requestedWork   String?
  estimatedBudget Decimal?        @db.Decimal(14, 3)
  city            String?
  addressLine1    String?
  nextFollowUpAt  DateTime?
  lostReason      String?
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedUser    User?           @relation("LeadAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  convertedClient Client?         @relation("LeadConvertedClient")
  activities      LeadActivity[]
  notes           Note[]
  quotations      Quotation[]
  documentLinks   DocumentLink[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([assignedUserId, nextFollowUpAt])
  @@map("leads")
}

model LeadActivity {
  id          String           @id @default(cuid())
  tenantId    String
  leadId      String
  userId      String?
  type        LeadActivityType
  subject     String
  description String?
  scheduledAt DateTime?
  completedAt DateTime?
  metadata    Json?
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

model Note {
  id             String         @id @default(cuid())
  tenantId       String
  userId         String?
  clientId       String?
  leadId         String?
  quotationId    String?
  invoiceId      String?
  deliveryNoteId String?
  projectId      String?
  paymentId      String?
  expenseId      String?
  body           String
  visibility     NoteVisibility @default(INTERNAL)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quotation      Quotation?     @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  deliveryNote   DeliveryNote?  @relation(fields: [deliveryNoteId], references: [id], onDelete: SetNull)
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  payment        Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  expense        Expense?       @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  documentLinks  DocumentLink[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  @@index([tenantId, deletedAt])
  @@index([projectId, createdAt])
  @@index([clientId, createdAt])
  @@map("notes")
}

model Category {
  id          String        @id @default(cuid())
  tenantId    String
  parentId    String?
  code        String
  name        String
  kind        CategoryKind  @default(BOTH)
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]    @relation("CategoryHierarchy")
  products    Product[]
  services    Service[]
  quotationItems QuotationItem[]
  invoiceItems InvoiceItem[]
  deliveryNoteItems DeliveryNoteItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@map("categories")
}

model Unit {
  id                  String                @id @default(cuid())
  tenantId            String
  code                String
  name                String
  symbol              String
  unitType            UnitType
  precision           Int                   @default(3)
  isActive            Boolean               @default(true)
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products            Product[]
  services            Service[]
  quotationItems      QuotationItem[]
  invoiceItems        InvoiceItem[]
  deliveryNoteItems   DeliveryNoteItem[]
  projectMeasurements ProjectMeasurement[]
  purchaseOrderItems  PurchaseOrderItem[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@map("units")
}

model Product {
  id                 String              @id @default(cuid())
  tenantId           String
  categoryId         String?
  unitId             String
  code               String
  sku                String?
  name               String
  description        String?
  basePrice          Decimal             @db.Decimal(14, 3)
  costPrice          Decimal?            @db.Decimal(14, 3)
  vatRate            Decimal             @default(0) @db.Decimal(5, 2)
  isActive           Boolean             @default(true)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit               Unit                @relation(fields: [unitId], references: [id], onDelete: Restrict)
  quotationItems     QuotationItem[]
  invoiceItems       InvoiceItem[]
  deliveryNoteItems  DeliveryNoteItem[]
  purchaseOrderItems PurchaseOrderItem[]
  inventoryItems     InventoryItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@map("products")
}

model Service {
  id                 String              @id @default(cuid())
  tenantId           String
  categoryId         String?
  unitId             String
  code               String
  name               String
  description        String?
  basePrice          Decimal             @db.Decimal(14, 3)
  costRate           Decimal?            @db.Decimal(14, 3)
  vatRate            Decimal             @default(0) @db.Decimal(5, 2)
  isActive           Boolean             @default(true)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit               Unit                @relation(fields: [unitId], references: [id], onDelete: Restrict)
  quotationItems     QuotationItem[]
  invoiceItems       InvoiceItem[]
  deliveryNoteItems  DeliveryNoteItem[]
  purchaseOrderItems PurchaseOrderItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@map("services")
}

model Quotation {
  id                   String                 @id @default(cuid())
  tenantId             String
  branchId             String?
  clientId             String
  leadId               String?
  numberingSequenceId  String?
  createdByUserId      String?
  number               String
  title                String
  reference            String?
  status               QuotationStatus       @default(DRAFT)
  issueDate            DateTime
  validUntil           DateTime?
  acceptedAt           DateTime?
  rejectedAt           DateTime?
  currency             String                @default("TND")
  subtotalAmount       Decimal               @default(0) @db.Decimal(14, 3)
  discountAmount       Decimal               @default(0) @db.Decimal(14, 3)
