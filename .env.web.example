# Copy this file to .env.web on the production server, then replace every secret.

# Public URL
APP_DOMAIN=erp.example.com
APP_URL=https://erp.example.com
ACME_EMAIL=admin@example.com

# The browser calls the API through the same HTTPS domain via Caddy.
NEXT_PUBLIC_API_URL=/api/v1
CORS_ORIGIN=https://erp.example.com

# Database container credentials
POSTGRES_DB=sotec_erp
POSTGRES_USER=sotec
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Initial owner account created on first login.
DEFAULT_TENANT_SLUG=sotec
DEFAULT_OWNER_EMAIL=admin@sotec.local
DEFAULT_OWNER_PASSWORD=ChangeMe123!

# Replace with independent random values before going live.
JWT_ACCESS_SECRET=replace-with-a-random-64-char-secret
JWT_REFRESH_SECRET=replace-with-another-random-64-char-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Uploaded documents are stored in the app_storage Docker volume.
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=/app/storage
