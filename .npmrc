# Hoisted node_modules (flat layout, like npm) instead of pnpm's default
# symlink-heavy virtual store. Required for the Windows installer build because:
#
#   1. Next.js's standalone tracer tries to follow real paths into the pnpm
#      virtual store and symlink them into apps/web/.next/standalone.
#   2. Windows blocks symlink creation unless Developer Mode is enabled or
#      the process runs as admin -> EPERM symlink failures during build.
#   3. Flat node_modules sidesteps the issue entirely: tracer copies files,
#      no symlinks needed.
#
# Trade-off: slightly larger node_modules on disk. Worth it for a reliable
# cross-platform installer build.
node-linker=hoisted

# Keep installs tolerant of peer ranges across the monorepo packages.
strict-peer-dependencies=false
